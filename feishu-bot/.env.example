PORT=8787

# Feishu / Lark app credentials
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=

# receive_id_type can be open_id, user_id, union_id, email, chat_id
FEISHU_DEFAULT_RECEIVE_ID_TYPE=open_id
FEISHU_DEFAULT_RECEIVE_ID=

# Optional: custom bot webhook for simple group pushes
FEISHU_CUSTOM_BOT_WEBHOOK=
FEISHU_CUSTOM_BOT_SECRET=

# Model provider
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

